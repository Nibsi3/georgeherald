{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "News categories"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "color": {
      "type": "string",
      "default": "#DC2626"
    },
    "icon": {
      "type": "string"
    },
    "parentSection": {
      "type": "enumeration",
      "enum": [
        "news",
        "sport",
        "lifestyle",
        "schools",
        "community",
        "opinion",
        "videos",
        "galleries"
      ]
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "category"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
